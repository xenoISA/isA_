# =============================================================================
# isA_ Frontend - Staging Environment
# =============================================================================

NODE_ENV=production
NEXT_PUBLIC_APP_ENV=staging

# APISIX Gateway
NEXT_PUBLIC_GATEWAY_URL=https://staging-gateway.iapro.ai

# Optional integrations
NEXT_PUBLIC_RUDDERSTACK_WRITE_KEY=your-staging-write-key
NEXT_PUBLIC_RUDDERSTACK_DATA_PLANE_URL=https://rudderstack-staging.iapro.ai
RUDDERSTACK_WEBHOOK_SECRET=staging-webhook-secret

NEXT_PUBLIC_SUPABASE_URL=https://your-staging-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key

# Feature flags
REACT_APP_ENABLE_AUTH=true
REACT_APP_ENABLE_FILE_UPLOAD=true
REACT_APP_ENABLE_REAL_TIME_CHAT=true
REACT_APP_ENABLE_WIDGETS=true
REACT_APP_ENABLE_DEBUG_MODE=false
REACT_APP_ENABLE_LOGGING_DASHBOARD=false
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_LOG_LEVEL=info
