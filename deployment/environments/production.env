# =============================================================================
# isA_ Frontend - Production Environment
# =============================================================================

NODE_ENV=production
NEXT_PUBLIC_APP_ENV=production

# APISIX Gateway
NEXT_PUBLIC_GATEWAY_URL=https://gateway.iapro.ai

# Optional integrations
NEXT_PUBLIC_RUDDERSTACK_WRITE_KEY=your-prod-write-key
NEXT_PUBLIC_RUDDERSTACK_DATA_PLANE_URL=https://rudderstack.iapro.ai
RUDDERSTACK_WEBHOOK_SECRET=prod-webhook-secret

NEXT_PUBLIC_SUPABASE_URL=https://your-prod-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-prod-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-prod-service-role-key

# Feature flags
REACT_APP_ENABLE_AUTH=true
REACT_APP_ENABLE_FILE_UPLOAD=true
REACT_APP_ENABLE_REAL_TIME_CHAT=true
REACT_APP_ENABLE_WIDGETS=true
REACT_APP_ENABLE_DEBUG_MODE=false
REACT_APP_ENABLE_LOGGING_DASHBOARD=false
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_LOG_LEVEL=warn
