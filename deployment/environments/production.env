# =============================================================================
# isA_ Frontend — Production Environment Template
# =============================================================================
# Copy to .env.production.local and fill in real values.
# NEVER commit real secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_APP_ENV=production

# -----------------------------------------------------------------------------
# Gateway (APISIX)
# -----------------------------------------------------------------------------
# REQUIRED: Production gateway URL — all API calls route through this.
# Build-time: NEXT_PUBLIC_* vars are inlined by Next.js at build time.
NEXT_PUBLIC_GATEWAY_URL=https://gateway.isa.ai

# OPTIONAL: Chat backend selector — 'agent' (default) or 'mate'.
# NEXT_PUBLIC_CHAT_BACKEND=agent

# OPTIONAL: Direct Mate URL (bypasses gateway routing for Mate service).
# NEXT_PUBLIC_MATE_URL=https://mate.isa.ai

# -----------------------------------------------------------------------------
# Surface / URL Configuration
# -----------------------------------------------------------------------------
# OPTIONAL: Override default surface URLs for multi-domain deployments.
# NEXT_PUBLIC_MARKETING_URL=/
# NEXT_PUBLIC_APP_URL=/app
# NEXT_PUBLIC_APP_DASHBOARD_URL=/app
# NEXT_PUBLIC_CONSOLE_URL=/console
# NEXT_PUBLIC_DOCS_URL=/docs
# NEXT_PUBLIC_MARKETING_HOSTS=isa.ai,www.isa.ai

# -----------------------------------------------------------------------------
# Analytics — RudderStack
# -----------------------------------------------------------------------------
# OPTIONAL: Remove if not using analytics.
# Get keys from: https://app.rudderstack.com -> Sources -> your source
NEXT_PUBLIC_RUDDERSTACK_WRITE_KEY=
NEXT_PUBLIC_RUDDERSTACK_DATA_PLANE_URL=
# SECRET — load from vault/K8s secrets
RUDDERSTACK_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Auth — Supabase
# -----------------------------------------------------------------------------
# OPTIONAL: Remove if not using Supabase for auth.
# Get keys from: https://supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SECRET — load from vault/K8s secrets
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Legacy Service URLs (migration — prefer gateway routing)
# -----------------------------------------------------------------------------
# These are passed through next.config.js for backward compatibility.
# Leave empty to use the gateway (recommended).
# REACT_APP_AGENT_SERVICE_URL=
# REACT_APP_USER_SERVICE_URL=
# REACT_APP_MODEL_SERVICE_URL=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
REACT_APP_ENABLE_AUTH=true
REACT_APP_ENABLE_FILE_UPLOAD=true
REACT_APP_ENABLE_REAL_TIME_CHAT=true
REACT_APP_ENABLE_WIDGETS=true
REACT_APP_ENABLE_DEBUG_MODE=false
REACT_APP_ENABLE_LOGGING_DASHBOARD=false
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_LOG_LEVEL=warn
