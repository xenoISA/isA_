# Legacy alias template.
# Please use `.env.example` as the canonical source.

NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_GATEWAY_URL=http://localhost:9080
NEXT_PUBLIC_RUDDERSTACK_WRITE_KEY=your-rudderstack-write-key
NEXT_PUBLIC_RUDDERSTACK_DATA_PLANE_URL=http://localhost:8102
RUDDERSTACK_WEBHOOK_SECRET=dev-webhook-secret
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
REACT_APP_ENABLE_AUTH=true
REACT_APP_ENABLE_FILE_UPLOAD=true
REACT_APP_ENABLE_REAL_TIME_CHAT=true
REACT_APP_ENABLE_WIDGETS=true
REACT_APP_ENABLE_DEBUG_MODE=true
REACT_APP_ENABLE_LOGGING_DASHBOARD=true
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_LOG_LEVEL=debug
